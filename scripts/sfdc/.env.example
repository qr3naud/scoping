# Salesforce JWT Bearer Flow credentials for the standalone tester.
#
# Copy this file to a per-environment dotenv (gitignored) and fill in real values:
#   .env.prod  -> production credentials (SFDC_LOGIN_URL=https://login.salesforce.com)
#   .env.uat   -> UAT sandbox credentials (SFDC_LOGIN_URL=https://test.salesforce.com)
#
# The tester picks one based on SFDC_ENV (default: prod):
#   SFDC_ENV=prod node apps/mono-calculator/scripts/sfdc/test-connection.mjs
#   SFDC_ENV=uat  node apps/mono-calculator/scripts/sfdc/test-connection.mjs
#
# For backward compatibility, a plain `.env` is used as a fallback if the
# selected `.env.<env>` file does not exist (with a console warning).

# Consumer Key from the External Client App
# (External Client App Manager > your app > Settings > OAuth Settings > Consumer Key and Secret)
SFDC_CLIENT_ID=

# The integration user's username.
# Prod example:  sfdc_integration@clay.com
# UAT  example:  clay-integration@clay.com.fulluat   (sandbox suffix required)
SFDC_USERNAME=

# Login endpoint:
#   https://login.salesforce.com  -> production
#   https://test.salesforce.com   -> sandboxes (UAT, full copy, etc.)
SFDC_LOGIN_URL=https://login.salesforce.com

# Path to the PRIVATE key file (the .key from the openssl pair). Absolute path or
# relative to the repo root works. Keep this file outside git (a sibling
# ~/secrets/ directory works well).
SFDC_PRIVATE_KEY_PATH=
