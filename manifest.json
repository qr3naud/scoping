{
  "manifest_version": 3,
  "name": "Clay Scoping Tool",
  "version": "3.4",
  "description": "Visual scoping canvas for Clay enrichment workflows",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://api.clay.com/*",
    "https://*.supabase.co/*",
    "http://localhost/*",
    "http://localhost:*/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:*/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "My Canvases",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://app.clay.com/*"],
      "js": [
        "vendor/supabase-realtime.js",
        "src/supabase.js",
        "src/config.js",
        "src/user.js",
        "src/workbook-info.js",
        "src/realtime.js",
        "src/api.js",
        "src/canvas/svg.js",
        "src/canvas/geometry.js",
        "src/canvas/graph-queries.js",
        "src/canvas/groups.js",
        "src/canvas/credits.js",
        "src/canvas/snap.js",
        "src/canvas/connections.js",
        "src/canvas/connect-flow.js",
        "src/canvas/ui.js",
        "src/canvas/cards.js",
        "src/canvas/persistence.js",
        "src/canvas/index.js",
        "src/canvas/collaborators.js",
        "src/canvas/cursors.js",
        "src/canvas/live-actions.js",
        "src/tabs.js",
        "src/picker.js",
        "src/table-import.js",
        "src/export.js",
        "src/overlay.js",
        "src/home.js",
        "src/toolbar.js"
      ],
      "css": [
        "styles/button.css",
        "styles/picker.css",
        "styles/overlay.css",
        "styles/canvas.css",
        "styles/cards.css",
        "styles/groups.css",
        "styles/pickers.css",
        "styles/collaborators.css",
        "styles/cursors.css",
        "styles/export.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/key-icon.png"],
      "matches": ["https://app.clay.com/*"]
    }
  ]
}
