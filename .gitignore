# Internal-only docs (architecture, business context) — kept on disk, never pushed to GitHub
docs/

# Build output for the public spin-off (see build.js / release.sh). The actual
# output lives wherever BUILD_OUT points at — typically a sibling clone of
# qr3naud/self-scoping — but if anyone redirects the build into a local dist/
# we don't want it tracked alongside the internal source.
dist/

# Chrome auto-generates this binary DNR ruleset cache when the unpacked
# extension is loaded. Per-machine, per-install — never check it in. The
# public build also excludes it via build.config.js exclude list.
_metadata/

# Supabase CLI runtime cache — created by `supabase functions deploy` etc.
# Per-machine; never check it in. supabase/config.toml and supabase/functions/
# + supabase/migrations/ are the only things from supabase/ that belong in git.
supabase/.temp/
