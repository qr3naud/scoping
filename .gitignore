# Internal-only docs (architecture, business context) — kept on disk, never pushed to GitHub
docs/

# Local build output, if any. Per-machine; never tracked alongside source.
dist/

# Chrome auto-generates this binary DNR ruleset cache when the unpacked
# extension is loaded. Per-machine, per-install — never check it in.
_metadata/

# Supabase CLI runtime cache — created by `supabase functions deploy` etc.
# Per-machine; never check it in. supabase/config.toml and supabase/functions/
# + supabase/migrations/ are the only things from supabase/ that belong in git.
supabase/.temp/
